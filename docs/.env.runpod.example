# =============================================================================
# CONFIGURAZIONE LUNA RPG v4 - RUNPOD EDITION
# =============================================================================
# Copia questo file in .env e modifica i valori con i tuoi dati

# =============================================================================
# MODO DI ESECUZIONE
# =============================================================================
# Per RunPod, imposta sempre: RUNPOD
EXECUTION_MODE=RUNPOD

# =============================================================================
# DATABASE (SQLite - locale al pod)
# =============================================================================
DATABASE_URL=sqlite+aiosqlite:///workspace/luna-rpg-v4/storage/luna.db

# =============================================================================
# STABLE DIFFUSION WEBUI (Immagini)
# =============================================================================
# Su RunPod, SD WebUI gira sulla porta 7860
SD_WEBUI_URL=http://localhost:7860

# Timeout aumentato per RunPod (secondi)
SD_WEBUI_TIMEOUT=600

# Abilita HTTP pollinng per controllare quando le immagini sono pronte
SD_WEBUI_USE_POLLING=true

# =============================================================================
# COMFYUI (Video)
# =============================================================================
# Su RunPod, ComfyUI gira sulla porta 8188
COMFYUI_URL=http://localhost:8188

# Timeout per generazione video (molto lungo, i video richiedono tempo)
COMFYUI_TIMEOUT=1800

# Workflow JSON per video (Wan 2.1)
# Questo file deve esistere nel progetto
COMFYUI_WORKFLOW_PATH=/workspace/luna-rpg-v4/comfy_workflow_video.json

# =============================================================================
# LLM PROVIDER (OpenRouter - Consigliato per RunPod)
# =============================================================================
# OpenRouter è il più facile da configurare su RunPod
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-v1-TUA_CHIAVE_QUI

# Modello consigliato per Luna RPG
DEFAULT_MODEL=google/gemini-2.0-flash-001

# Backup model (se il primo fallisce)
FALLBACK_MODEL=anthropic/claude-3.5-haiku

# Alternative (scommenta quella che preferisci):
# DEFAULT_MODEL=anthropic/claude-3.5-sonnet
# DEFAULT_MODEL=google/gemini-pro-1.5
# DEFAULT_MODEL=meta-llama/llama-3.3-70b-instruct

# =============================================================================
# ELEVENLABS (Audio TTS)
# =============================================================================
ELEVENLABS_API_KEY=sk_TUA_CHIAVE_ELEVENLABS
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM  # Voice di default (Bella)

# =============================================================================
# CONFIGURAZIONE IMMAGINI
# =============================================================================
# Abilita generazione immagini
ENABLE_IMAGES=true

# Prompt di base (verrà combinato con quello del personaggio)
IMAGE_BASE_PROMPT=masterpiece, best quality, photorealistic, detailed

# Negative prompt
IMAGE_NEGATIVE_PROMPT=lowres, bad anatomy, bad hands, text, error, missing fingers

# Dimensioni immagine (SD 1.5: 512x768, SDXL: 768x1216, Pony: 832x1216)
IMAGE_WIDTH=832
IMAGE_HEIGHT=1216

# Steps e CFG
IMAGE_STEPS=30
IMAGE_CFG=7

# =============================================================================
# CONFIGURAZIONE VIDEO
# =============================================================================
# Abilita generazione video
ENABLE_VIDEO=true

# Frame per video
VIDEO_FRAMES=81

# FPS video finale
VIDEO_FPS=16

# Dimensioni video (480p è consigliato per Wan 2.1)
VIDEO_WIDTH=832
VIDEO_HEIGHT=480

# =============================================================================
# CONFIGURAZIONE AUDIO
# =============================================================================
# Abilita audio TTS
ENABLE_AUDIO=true

# Volume audio (0.0 - 1.0)
AUDIO_VOLUME=0.8

# =============================================================================
# MEMORY SYSTEM
# =============================================================================
# Numero di messaggi da mantenere nel contesto
MEMORY_CONTEXT_MESSAGES=20

# Importanza minima per ricordare fatti
MEMORY_MIN_IMPORTANCE=5

# Max fatti da includere nel contesto
MEMORY_MAX_FACTS=5

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO

# Salva log su file
LOG_TO_FILE=true
LOG_FILE_PATH=/workspace/luna-rpg-v4/logs/luna.log

# =============================================================================
# AVANZATE (non modificare se non sai cosa fai)
# =============================================================================
# HuggingFace cache (per modelli)
HF_HOME=/workspace/cache/huggingface

# Transformers cache
TRANSFORMERS_CACHE=/workspace/cache/transformers

# ComfyUI extra model paths (se hai modelli condivisi)
# COMFYUI_EXTRA_MODEL_PATHS=/workspace/shared_models
